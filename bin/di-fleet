#!/usr/bin/env bash
# di-fleet: run `di` (divergent-ideation) on a live fleet MoE slot automatically.
# No manual DIVERGENT_LLM_BASE_URL/MODEL. Picks a live LLM by capability, prefers
# a decode-verified warm slot, falls back to di's own default if the fleet is empty.
set -uo pipefail
FLEET=/home/halbritt/git/gpu-fleet
DI_CLI=/home/halbritt/git/divergent-ideation/dist/cli.js

route() { python3 "$FLEET/pick_slot.py" "$@" -k 8 --json 2>/dev/null || echo '[]'; }
# di needs an OpenAI-compatible HTTP LLM endpoint -- never a non-LLM capability
# slot (e.g. marker's ssh:// endpoint), so filter to http(s). Then prefer a
# decode-verified WARM slot (real probe_ms) over a capability-only/cold one, so di
# lands on a ready MoE instead of cold-loading a 23 GiB model that may be sharing
# its GPU with marker.
pick_llm() {
  jq -c '([ .[] | select((.endpoint_url|test("^https?://")) and .probe_ms != null) ]
        + [ .[] | select(  .endpoint_url|test("^https?://") ) ])[0] // empty'
}
pick=$(route | pick_llm)

endpoint=$(jq -r '.endpoint_url // empty' <<<"${pick:-}" 2>/dev/null)
model=$(jq -r '.served_model // empty' <<<"${pick:-}" 2>/dev/null)

if [ -n "$endpoint" ]; then
  echo "di-fleet -> $endpoint ($model)" >&2
  export DIVERGENT_LLM_BASE_URL="$endpoint"
  export DIVERGENT_LLM_MODEL="$model"
else
  echo "di-fleet: no live fleet slot; using di defaults (localhost:8081)" >&2
fi
exec node "$DI_CLI" "$@"
